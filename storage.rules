// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Band Photos ───────────────────────────────────────────
    // Authenticated users can upload to photos/.
    // Anyone can read (public gallery of approved photos).
    // Only admins can delete (enforced at Firestore level too).
    match /photos/{filename} {
      allow read:   if true;
      allow create: if request.auth != null
                    && request.resource.size < 10 * 1024 * 1024   // max 10MB per photo
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // ── Sponsor Logos ─────────────────────────────────────────
    match /sponsors/{filename} {
      allow read:   if true;
      allow write:  if request.auth != null;
    }
  }
}
